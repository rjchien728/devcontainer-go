{
	"name": "my-project",
	"image": "devcontainer-go:1.21",
	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
			"moby": false
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "none",
			"pnpmVersion": "latest"
		}
	},
	"workspaceFolder": "/my-project",
	"mounts": [
		"source=${localWorkspaceFolder},target=/my-project,type=bind,consistency=cached"
	],
	"runArgs": [
		"--add-host=host.docker.internal:host-gateway",
		"--name=vsc-my-project"
	],
	"postCreateCommand": "go mod tidy",
	"postStartCommand": "sudo bash /usr/local/bin/post-start-cmd.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.go",
				"eamodio.gitlens",
				"drblury.protobuf-vsc"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh"
			}
		}
	},
	"forwardPorts": [
		8080
	],
	"portsAttributes": {
		"8080": {
			"label": "Web API",
			"onAutoForward": "openBrowser"
		}
	}
}